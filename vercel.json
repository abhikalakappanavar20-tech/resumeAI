{
    "version": 2,
    "builds": [
        {
            "src": "vercel_app/index.py",
            "use": "@vercel/python",
            "config": {
                "maxDuration": 30
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "vercel_app/index.py"
        }
    ]
}
